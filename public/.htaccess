# Hostinger/Apache SEO + SPA routing + Cache rules for Hogar San Blas

# Enable mod_rewrite
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Canonical host (remove www)
  RewriteCond %{HTTP_HOST} ^www\.hogarsanblas\.com$ [NC]
  RewriteRule ^ https://hogarsanblas.com%{REQUEST_URI} [R=301,L,NE]

  # Force HTTPS with permanent redirect
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://hogarsanblas.com%{REQUEST_URI} [R=301,L,NE]

  # Serve real files/folders directly (robots.txt, sitemap.xml, assets, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback for client routes
  RewriteRule . /index.html [L]
</IfModule>

# Enable mod_expires and mod_headers
<IfModule mod_expires.c>
  ExpiresActive On
</IfModule>

# Caché para assets compilados con hash (JS, CSS, fonts) - 1 año (muy larga porque tienen hash)
<FilesMatch "\.(js|css|woff2?|ttf|eot|otf)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=31536000, immutable"
  </IfModule>
  <IfModule mod_expires.c>
    ExpiresDefault "access plus 1 year"
  </IfModule>
</FilesMatch>

# Caché para webp y imágenes - 30 días
<FilesMatch "\.(webp|jpg|jpeg|png|gif|ico|svg)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=2592000"
  </IfModule>
  <IfModule mod_expires.c>
    ExpiresDefault "access plus 30 days"
  </IfModule>
</FilesMatch>

# HTML: validar siempre (1 hora)
<FilesMatch "\.html?$">
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </IfModule>
  <IfModule mod_expires.c>
    ExpiresDefault "access plus 1 hour"
  </IfModule>
</FilesMatch>

# JSON: validar siempre (1 hora)
<FilesMatch "\.json$">
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </IfModule>
  <IfModule mod_expires.c>
    ExpiresDefault "access plus 1 hour"
  </IfModule>
</FilesMatch>

# XML: validar siempre (1 hora)
<FilesMatch "\.(xml|sitemap)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </IfModule>
  <IfModule mod_expires.c>
    ExpiresDefault "access plus 1 hour"
  </IfModule>
</FilesMatch>

# Compresión gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
  application/json
</IfModule>